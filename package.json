{
  "name": "toru-toru-land",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "cd apps/web && NEXT_TELEMETRY_DISABLED=1 node ../../node_modules/.bin/next dev --hostname 127.0.0.1 --port 3000",
    "build": "npm run build --workspace @toru/web",
    "typecheck": "npm run typecheck --workspace @toru/web",
    "lint": "npm run lint --workspace @toru/web"
  },
  "workspaces": [
    "apps/web"
  ],
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
